# Скопируйте в файл `.env` в корне проекта

# ============================================
# ОБЯЗАТЕЛЬНЫЕ ПАРАМЕТРЫ
# ============================================

# Telegram bot token (получить у @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Google Gemini API keys (получить на https://aistudio.google.com/apikey)
# Поддержка множественных ключей для автоматического fallback:
# При исчерпании лимита одного ключа система автоматически переключится на следующий
GEMINI_API_KEY_1=your_first_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_here
# GEMINI_API_KEY_3=your_third_gemini_api_key_here
# GEMINI_API_KEY_4=your_fourth_gemini_api_key_here

# Примечание: Старый формат GEMINI_API_KEY все еще поддерживается для обратной совместимости
# Если указан только GEMINI_API_KEY, он будет использован как единственный ключ
# GEMINI_API_KEY=your_gemini_api_key_here


# ============================================
# DATABASE (PostgreSQL)
# ============================================
# PostgreSQL connection string: "postgresql://user:password@host:port/dbname"
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/itempo




# ============================================
# TELEGRAM (опционально)
# ============================================

# Whitelist пользователей (ID через запятую, пусто = доступ всем)
# Узнать свой ID: напишите @userinfobot
# TELEGRAM_WHITELIST=123456789,987654321


# ============================================
# ПРОКСИ (опционально)
# ============================================

# HTTP/HTTPS прокси для Gemini API (переименованы во избежание конфликтов)
# BOT_HTTPS_PROXY=http://user:pass@host:port
# BOT_HTTP_PROXY=http://user:pass@host:port

# Пропустить проверку доступности прокси (1 = да, 0 = нет)
# BOT_FORCE_PROXY=0


# ============================================
# АДМИНИСТРАТИВНАЯ ПАНЕЛЬ (СЕКРЕТЫ)
# ============================================
# Пароль для доступа к административной панели
ADMIN_PASSWORD=tempo_admin_2024



# ============================================
# INTRASERVICE / HELPDESK TICKETS (опционально)
# ============================================

# Базовый URL IntraService, например: https://helpdesk.company.local
# INTRASERVICE_BASE_URL=

# Basic Auth credentials (используются ТОЛЬКО если включен HELPDESK_ALLOW_BASIC_FALLBACK=1
# или выбран HELPDESK_AUTH_MODE=basic)
# INTRASERVICE_LOGIN=
# INTRASERVICE_PASSWORD=

# Fallback сервис "11. Общие вопросы"
# INTRASERVICE_ALL_SERVICE_CODE=All

# Явные ID (если хотите зафиксировать и не искать по справочникам)
# INTRASERVICE_DEFAULT_SERVICE_ID=
# INTRASERVICE_DEFAULT_TYPE_ID=
# INTRASERVICE_INITIAL_STATUS_ID=
# INTRASERVICE_MEDIUM_PRIORITY_ID=

# Если /api/taskstatus недоступен (500 на стороне Helpdesk), разрешить создание тикета без StatusId.
# Рекомендуется 1 для нестабильных инсталляций API.
# INTRASERVICE_ALLOW_CREATE_WITHOUT_STATUS=1

# Включить автоназначение (резерв для дальнейшей логики)
# AUTO_ASSIGN_ENABLED=0

# Порог уверенности классификации сервиса/типа
# TRIAGE_CONFIDENCE_THRESHOLD=0.70

# Если запрос длиннее этого лимита, заявка маршрутизируется в сервис All
# TICKET_LONG_CONTEXT_CHARS=4000

# Добавлять отметку [AI Assistant] в Name заявки
# TICKET_AUTO_MARK_ENABLED=1

# Создавать заявку от имени найденного пользователя IntraService (по AD login)
# Требует совпадения user_login Desktop и login в IntraService (/api/user?login=...)
# TICKET_CREATE_ON_BEHALF=1

# Режим аутентификации к Helpdesk API:
# negotiate | kerberos | ntlm | basic
# По умолчанию рекомендуется negotiate (Kerberos first, NTLM fallback).
HELPDESK_AUTH_MODE=negotiate

# Разрешить аварийный fallback на Basic при неудаче Negotiate.
# Для production с требованием "от лица пользователя" рекомендуется 0.
HELPDESK_ALLOW_BASIC_FALLBACK=0

# Требовать успешную delegation перед созданием заявки.
# При 1 и провале delegation тикет не создается, сохраняется черновик.
HELPDESK_REQUIRE_DELEGATION=1

# Источник идентичности пользователя для on-behalf маппинга.
# login | upn | email
HELPDESK_IDENTITY_SOURCE=login

# SPN целевого Helpdesk сервиса (опционально для диагностики/политик).
HELPDESK_SPN=HTTP/helpdesk.company.local

# Принудительно считать negotiate-схему Kerberos (без попытки определить NTLM по challenge).
HELPDESK_NEGOTIATE_FORCE_KERBEROS=0

# --- Рекомендуемый production профиль (Kerberos/RBCD) ---
# 1) Убедитесь, что backend запущен под gMSA/domain service account.
# 2) Для строгого требования "от лица пользователя":
#    HELPDESK_AUTH_MODE=negotiate
#    HELPDESK_REQUIRE_DELEGATION=1
#    HELPDESK_ALLOW_BASIC_FALLBACK=0
#    HELPDESK_IDENTITY_SOURCE=login
#    TICKET_CREATE_ON_BEHALF=1

# --- Диагностический профиль (временно) ---
# Разрешает аварийный Basic fallback для поиска инфраструктурных проблем:
# HELPDESK_AUTH_MODE=negotiate
# HELPDESK_REQUIRE_DELEGATION=0
# HELPDESK_ALLOW_BASIC_FALLBACK=1
# INTRASERVICE_LOGIN=...
# INTRASERVICE_PASSWORD=...

# ============================================
# SSL VERIFICATION ДЛЯ INTRASERVICE (опционально)
# ============================================

# Путь к локальному SSL сертификату для доверия внутреннему сервису
# Например: cert/ServiceDesk.corporate.loc.crt
# INTRASERVICE_SSL_CERT_PATH=cert/ServiceDesk.corporate.loc.crt

# Настройка проверки SSL:
# - Путь к сертификату/CA bundle: INTRASERVICE_SSL_VERIFY=cert/ServiceDesk.corporate.loc.crt
# - True: строгая проверка системными сертификатами
# - False: отключить проверку SSL (не рекомендуется в production)
# INTRASERVICE_SSL_VERIFY=cert/ServiceDesk.corporate.loc.crt
