# Скопируйте в файл `.env` в корне проекта

# ============================================
# ОБЯЗАТЕЛЬНЫЕ ПАРАМЕТРЫ
# ============================================

# Telegram bot token (получить у @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Google Gemini API keys (получить на https://aistudio.google.com/apikey)
# Поддержка множественных ключей для автоматического fallback:
# При исчерпании лимита одного ключа система автоматически переключится на следующий
GEMINI_API_KEY_1=your_first_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_here
# GEMINI_API_KEY_3=your_third_gemini_api_key_here
# GEMINI_API_KEY_4=your_fourth_gemini_api_key_here

# Примечание: Старый формат GEMINI_API_KEY все еще поддерживается для обратной совместимости
# Если указан только GEMINI_API_KEY, он будет использован как единственный ключ
# GEMINI_API_KEY=your_gemini_api_key_here


# ============================================
# DATABASE (PostgreSQL)
# ============================================
# PostgreSQL connection string: "postgresql://user:password@host:port/dbname"
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/itempo

# ============================================
# МОДЕЛИ (опционально, по умолчанию из models_config.yaml)
# ============================================
# ВАЖНО: Основные настройки моделей находятся в models_config.yaml
# Здесь можно переопределить отдельные параметры для конкретного окружения

# Текстовая модель для генерации ответов
# Дефолт из YAML: gemini-1.5-flash
# Альтернативы: gemini-2.0-flash-exp, gemini-1.5-pro, gemini-2.5-flash, gemma-3-27b-it
# GEMINI_TEXT_MODEL=gemini-1.5-flash

# Альтернативные текстовые модели при перегрузке основной (через запятую)
# Система автоматически переключится на них при 503 ошибках
# Учитывайте версии API: v1 (gemini-1.5-*), v1beta (gemini-2.0-*), v1alpha (gemini-2.5-*, gemma-3-*)
# GEMINI_TEXT_MODEL_FALLBACK=gemini-1.5-flash, gemini-2.5-flash

# Параметры генерации текстовой модели
# TEXT_TEMPERATURE=0.5
# TEXT_TOP_P=0.95
# TEXT_TOP_K=64

# Голосовая модель для Live API
# Дефолт из YAML: gemini-2.5-flash-native-audio-latest
# GEMINI_AUDIO_MODEL=gemini-2.5-flash-native-audio-latest

# Параметры генерации голосовой модели
# AUDIO_TEMPERATURE=1.0
# AUDIO_VOICE_NAME=Kore

# Embedding модель с Matryoshka Representation Learning (MRL)
# Дефолт из YAML: gemini-embedding-001
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001


# ============================================
# API ВЕРСИИ (опционально, по умолчанию из models_config.yaml)
# ============================================

# Embedding API версия (дефолт из YAML: v1beta)
# EMBEDDING_API_VERSION=v1beta

# Text API версия (дефолт из YAML: null, авто-определение)
# TEXT_API_VERSION=

# Live API версия для WebSocket соединений (дефолт из YAML: v1alpha)
# LIVE_API_VERSION=v1alpha


# ============================================
# RAG ПАРАМЕТРЫ (опционально)
# ============================================

# Размерность векторов (768, 1536 или 3072)
# Рекомендуется: 1536 (баланс качества/производительности)
# VECTOR_SIZE=1536

# Размер чанков документов (в символах)
# CHUNK_SIZE=1000

# Перекрытие между чанками (в символах)
# CHUNK_OVERLAP=200

# Название коллекции в Qdrant
# COLLECTION_NAME=documents

# Лимит результатов поиска (передается в LLM)
# SEARCH_LIMIT=10

# Лимит кандидатов для hybrid search (до re-ranking)
# FETCH_LIMIT=20


# ============================================
# РАСШИРЕННЫЙ RAG PIPELINE (опционально)
# ============================================
# Все параметры: 1 = включено, 0 = выключено

# Contextual Retrieval - добавление контекста к чанкам через LLM
# ВНИМАНИЕ: Затратно! Требует LLM запросов при индексации
# USE_CONTEXTUAL_RETRIEVAL=0

# Hybrid Search - Vector + BM25 + RRF fusion
# Рекомендуется включить для лучшего качества поиска
# USE_HYBRID_SEARCH=1

# RAG Fusion - генерация вариаций запроса для multi-query поиска
# ВНИМАНИЕ: Затратно! +N LLM запросов на каждый поиск
# USE_RAG_FUSION=0

# LLM Reranking - переранжирование результатов через LLM
# ВНИМАНИЕ: Затратно! +1 LLM запрос на каждый поиск
# USE_LLM_RERANK=0

# Fallback - адаптивный фоллбэк на базе объединенного CRAG + HyDE запроса при низком качестве результатов
# USE_FALLBACK=1

# Semantic Chunking - чанкинг по семантическим границам
# ВНИМАНИЕ: ОЧЕНЬ затратно на embeddings при индексации!
# USE_SEMANTIC_CHUNKING=0

# Parent-Child Chunking - двухуровневые чанки (мелкие для поиска, крупные для контекста)
# USE_PARENT_CHILD_CHUNKS=0

# Сбор метрик поиска (записываются в logs/metrics/)
# ENABLE_METRICS=1

# Инкрементальное обновление базы (обрабатывать только изменённые файлы)
# USE_INCREMENTAL_UPDATES=1


# ============================================
# ДЕТАЛЬНЫЕ RAG НАСТРОЙКИ (опционально)
# ============================================

# Contextual Retrieval (дефолты из models_config.yaml)
# CONTEXTUAL_TEXT_MODEL=gemini-1.5-flash
# CONTEXTUAL_MAX_DOC_CHARS=12000
# CONTEXTUAL_PARALLELISM=4

# Hybrid Search
# VECTOR_FETCH_LIMIT=50
# BM25_FETCH_LIMIT=50
# FUSION_FETCH_LIMIT=20
# RRF_K=60

# RAG Fusion
# QUERY_VARIATIONS=3

# LLM Rerank
# RERANK_TOP_K=5
# RERANK_MAX_DOCS=20
# RERANK_DOC_CHARS=500


# Semantic Chunking
# SEMANTIC_CHUNK_SIZE=1000
# SEMANTIC_SIMILARITY_THRESHOLD=0.75

# Parent-Child Chunking
# PARENT_CHUNK_SIZE=1500
# CHILD_CHUNK_SIZE=300

# Путь к файлу хэшей документов (для инкрементального обновления)
# DOCUMENT_HASHES_PATH=qdrant_storage/document_hashes.json


# ============================================
# TELEGRAM (опционально)
# ============================================

# Whitelist пользователей (ID через запятую, пусто = доступ всем)
# Узнать свой ID: напишите @userinfobot
# TELEGRAM_WHITELIST=123456789,987654321


# ============================================
# ПРОКСИ (опционально)
# ============================================

# HTTP/HTTPS прокси для Gemini API (переименованы во избежание конфликтов)
# BOT_HTTPS_PROXY=http://user:pass@host:port
# BOT_HTTP_PROXY=http://user:pass@host:port

# Пропустить проверку доступности прокси (1 = да, 0 = нет)
# BOT_FORCE_PROXY=0


# ============================================
# MEMORY CHAT (опционально)
# ============================================

# Включить сохранение истории разговоров
# CHAT_HISTORY_ENABLED=1

# Путь к базе данных истории (относительно корня проекта)
# CHAT_HISTORY_DB_PATH=chat_history.db

# Максимальное количество последних сообщений в контексте
# MAX_HISTORY_MESSAGES=20

# Порог для автоматической суммаризации (количество сообщений)
# SUMMARIZATION_THRESHOLD=50

# Максимальное количество токенов для истории
# MAX_CONTEXT_TOKENS=8000

# Включить автоматическую суммаризацию длинных разговоров
# ENABLE_AUTO_SUMMARIZATION=1


# ============================================
# INTRASERVICE / HELPDESK TICKETS (опционально)
# ============================================

# Базовый URL IntraService, например: https://helpdesk.company.local
# INTRASERVICE_BASE_URL=

# Basic Auth credentials (используются ТОЛЬКО если включен HELPDESK_ALLOW_BASIC_FALLBACK=1
# или выбран HELPDESK_AUTH_MODE=basic)
# INTRASERVICE_LOGIN=
# INTRASERVICE_PASSWORD=

# Fallback сервис "11. Общие вопросы"
# INTRASERVICE_ALL_SERVICE_CODE=All

# Явные ID (если хотите зафиксировать и не искать по справочникам)
# INTRASERVICE_DEFAULT_SERVICE_ID=
# INTRASERVICE_DEFAULT_TYPE_ID=
# INTRASERVICE_INITIAL_STATUS_ID=
# INTRASERVICE_MEDIUM_PRIORITY_ID=

# Если /api/taskstatus недоступен (500 на стороне Helpdesk), разрешить создание тикета без StatusId.
# Рекомендуется 1 для нестабильных инсталляций API.
# INTRASERVICE_ALLOW_CREATE_WITHOUT_STATUS=1

# Включить автоназначение (резерв для дальнейшей логики)
# AUTO_ASSIGN_ENABLED=0

# Порог уверенности классификации сервиса/типа
# TRIAGE_CONFIDENCE_THRESHOLD=0.70

# Если запрос длиннее этого лимита, заявка маршрутизируется в сервис All
# TICKET_LONG_CONTEXT_CHARS=4000

# Добавлять отметку [AI Assistant] в Name заявки
# TICKET_AUTO_MARK_ENABLED=1

# Создавать заявку от имени найденного пользователя IntraService (по AD login)
# Требует совпадения user_login Desktop и login в IntraService (/api/user?login=...)
# TICKET_CREATE_ON_BEHALF=1

# Режим аутентификации к Helpdesk API:
# negotiate | kerberos | ntlm | basic
# По умолчанию рекомендуется negotiate (Kerberos first, NTLM fallback).
HELPDESK_AUTH_MODE=negotiate

# Разрешить аварийный fallback на Basic при неудаче Negotiate.
# Для production с требованием "от лица пользователя" рекомендуется 0.
HELPDESK_ALLOW_BASIC_FALLBACK=0

# Требовать успешную delegation перед созданием заявки.
# При 1 и провале delegation тикет не создается, сохраняется черновик.
HELPDESK_REQUIRE_DELEGATION=1

# Источник идентичности пользователя для on-behalf маппинга.
# login | upn | email
HELPDESK_IDENTITY_SOURCE=login

# SPN целевого Helpdesk сервиса (опционально для диагностики/политик).
HELPDESK_SPN=HTTP/helpdesk.company.local

# Принудительно считать negotiate-схему Kerberos (без попытки определить NTLM по challenge).
HELPDESK_NEGOTIATE_FORCE_KERBEROS=0

# --- Рекомендуемый production профиль (Kerberos/RBCD) ---
# 1) Убедитесь, что backend запущен под gMSA/domain service account.
# 2) Для строгого требования "от лица пользователя":
#    HELPDESK_AUTH_MODE=negotiate
#    HELPDESK_REQUIRE_DELEGATION=1
#    HELPDESK_ALLOW_BASIC_FALLBACK=0
#    HELPDESK_IDENTITY_SOURCE=login
#    TICKET_CREATE_ON_BEHALF=1

# --- Диагностический профиль (временно) ---
# Разрешает аварийный Basic fallback для поиска инфраструктурных проблем:
# HELPDESK_AUTH_MODE=negotiate
# HELPDESK_REQUIRE_DELEGATION=0
# HELPDESK_ALLOW_BASIC_FALLBACK=1
# INTRASERVICE_LOGIN=...
# INTRASERVICE_PASSWORD=...

# ============================================
# SSL VERIFICATION ДЛЯ INTRASERVICE (опционально)
# ============================================

# Путь к локальному SSL сертификату для доверия внутреннему сервису
# Например: cert/ServiceDesk.corporate.loc.crt
# INTRASERVICE_SSL_CERT_PATH=cert/ServiceDesk.corporate.loc.crt

# Настройка проверки SSL:
# - Путь к сертификату/CA bundle: INTRASERVICE_SSL_VERIFY=cert/ServiceDesk.corporate.loc.crt
# - True: строгая проверка системными сертификатами
# - False: отключить проверку SSL (не рекомендуется в production)
# INTRASERVICE_SSL_VERIFY=cert/ServiceDesk.corporate.loc.crt
